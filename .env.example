# Groq API key for the AI chat assistant
# Get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Passcode for /tools/private (AJ-only Funnel Section Builder)
PRIVATE_TOOL_PASSCODE=set_a_strong_passcode_here

# Random secret used to sign the auth cookie (any long random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PRIVATE_TOOL_COOKIE_SECRET=generate_a_random_64_char_hex_string
